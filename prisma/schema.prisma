generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Skill {
  id           String   @id @default(cuid())
  shop         String
  name         String
  trigger      String
  instructions String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([shop, trigger])
}

model McpServer {
  id        String   @id @default(cuid())
  shop      String
  name      String
  url       String
  authToken String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, name])
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model chat_messages {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chat_id        String          @db.Uuid
  role           String
  model_provider String?
  model_name     String?
  content        String?
  image_urls     String[]
  tool_calls     Json?
  created_at     DateTime        @default(now()) @db.Timestamptz(6)
  chats          chats           @relation(fields: [chat_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  credit_ledger  credit_ledger[]

  @@index([chat_id], map: "idx_chat_messages_chat_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model chats {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id       String          @db.Uuid
  title         String?
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  updated_at    DateTime        @default(now()) @db.Timestamptz(6)
  chat_messages chat_messages[]
  shops         shops           @relation(fields: [shop_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([shop_id], map: "idx_chats_shop_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model credit_ledger {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id          String         @db.Uuid
  chat_message_id  String?        @db.Uuid
  model_provider   String?
  model_name       String?
  input_tokens     Int?
  output_tokens    Int?
  real_cost_usd    Decimal        @db.Decimal(12, 6)
  credits_deducted BigInt
  overage_billed   Boolean        @default(false)
  created_at       DateTime       @default(now()) @db.Timestamptz(6)
  chat_messages    chat_messages? @relation(fields: [chat_message_id], references: [id], onUpdate: NoAction)
  shops            shops          @relation(fields: [shop_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([shop_id], map: "idx_credit_ledger_shop_id")
}

/// Generated images (gpt-image-2) held server-side so they can be previewed
/// in chat and, on merchant approval, uploaded to the store's Files. Bytes are
/// stored base64 in `data` and served only to the owning shop.
model generated_images {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id    String   @db.Uuid
  prompt     String
  mime_type  String
  data       String
  width      Int?
  height     Int?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  shops      shops    @relation(fields: [shop_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([shop_id], map: "idx_generated_images_shop_id")
}

/// Customer CSV exports (Phase 8). Sensitive PII — held only long enough for
/// the merchant to download, then expired/deleted. `expires_at` is enforced
/// lazily on access and on each new export. Never logged.
model customer_exports {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id    String   @db.Uuid
  filename   String
  data       String
  row_count  Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  expires_at DateTime @db.Timestamptz(6)
  shops      shops    @relation(fields: [shop_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([shop_id], map: "idx_customer_exports_shop_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model mcp_connections {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id              String   @db.Uuid
  name                 String
  server_url           String
  // UNBUILT: no code writes this column yet (the automation-email feature was rolled back). Whoever builds it MUST encrypt the token before writing it here — the name promises encryption at rest that does not exist anywhere yet; do not store plaintext under it.
  auth_token_encrypted String?
  enabled              Boolean  @default(true)
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  shops                shops    @relation(fields: [shop_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([shop_id], map: "idx_mcp_connections_shop_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model shops {
  id                   String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_domain          String            @unique
  plan                 String            @default("starter")
  credit_balance       BigInt            @default(0)
  billing_period_start DateTime          @default(now()) @db.Timestamptz(6)
  created_at           DateTime          @default(now()) @db.Timestamptz(6)
  updated_at           DateTime          @default(now()) @db.Timestamptz(6)
  email                String?
  // Live status of the shop's in-progress chat turn (e.g. "Thinking…",
  // "Searching products…"), polled by the chat UI. Null when no turn is
  // running. One turn per shop at a time (the composer blocks while busy).
  current_step         String?
  chats                chats[]
  credit_ledger        credit_ledger[]
  customer_exports     customer_exports[]
  generated_images     generated_images[]
  mcp_connections      mcp_connections[]
  skills               skills[]
  usage_logs           usage_logs[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model skills {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id          String   @db.Uuid
  name             String
  trigger          String
  instructions     String
  is_starter_skill Boolean  @default(false)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)
  shops            shops    @relation(fields: [shop_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([shop_id, trigger])
  @@index([shop_id], map: "idx_skills_shop_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model usage_logs {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id                String   @db.Uuid
  billing_period_start   DateTime @db.Timestamptz(6)
  total_credits_used     BigInt   @default(0)
  total_real_cost_usd    Decimal  @default(0) @db.Decimal(12, 6)
  message_count          Int      @default(0)
  created_at             DateTime @default(now()) @db.Timestamptz(6)
  updated_at             DateTime @default(now()) @db.Timestamptz(6)
  overage_dollars_billed Decimal  @default(0) @db.Decimal(12, 6)
  shops                  shops    @relation(fields: [shop_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([shop_id, billing_period_start])
}
